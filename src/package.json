{
  "name": "falah",
  "version": "1.1.1",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:dev-client": "node scripts/start-dev-client-with-env.mjs",
    "typecheck": "tsc --noEmit",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "maestro:smoke": "maestro test .maestro/smoke.yaml",
    "lint": "eslint . --ext .ts,.tsx",
    "build:quran-bundle": "node scripts/build-quran-bundle.mjs",
    "build:tier-map": "node scripts/build-tier-map.mjs",
    "deploy:get-r2-asset-stream": "npm run build:tier-map && supabase functions deploy get-r2-asset-stream",
    "upload:assets": "node scripts/upload-premium-assets-r2.mjs",
    "upload:assets:dry": "node scripts/upload-premium-assets-r2.mjs --dry-run",
    "upload:assets:verify": "node scripts/upload-premium-assets-r2.mjs --verify"
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "^react-native-mmkv$": "<rootDir>/__mocks__/react-native-mmkv.ts",
      "^@react-native-async-storage/async-storage$": "<rootDir>/__mocks__/async-storage.js"
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.test.tsx"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|native-base|react-native-svg))"
    ]
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "15.0.0",
    "@sentry/react-native": "~7.11.0",
    "@shopify/flash-list": "2.0.2",
    "@supabase/supabase-js": "^2.105.3",
    "@types/aes-js": "^3.1.4",
    "adhan": "^4.4.3",
    "aes-js": "^3.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "~55.0.24",
    "expo-apple-authentication": "~55.0.13",
    "expo-asset": "~55.0.17",
    "expo-audio": "^55.0.14",
    "expo-background-task": "~55.0.18",
    "expo-blur": "~55.0.14",
    "expo-constants": "~55.0.16",
    "expo-crypto": "~55.0.15",
    "expo-dev-client": "~55.0.33",
    "expo-file-system": "~55.0.19",
    "expo-font": "~55.0.7",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.10",
    "expo-keep-awake": "~55.0.8",
    "expo-linking": "~55.0.15",
    "expo-localization": "~55.0.14",
    "expo-location": "~55.1.10",
    "expo-notifications": "~55.0.23",
    "expo-router": "~55.0.14",
    "expo-secure-store": "~55.0.14",
    "expo-sensors": "~55.0.15",
    "expo-status-bar": "~55.0.6",
    "expo-store-review": "~55.0.14",
    "expo-symbols": "~55.0.8",
    "expo-task-manager": "~55.0.16",
    "expo-updates": "~55.0.22",
    "hijri-converter": "^1.1.1",
    "i18next": "^26.0.8",
    "moti": "^0.30.0",
    "nativewind": "^4.2.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^17.0.6",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.6",
    "react-native-purchases": "^10.0.1",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "^0.7.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19",
    "tus-js-client": "^4.3.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.2.2",
    "@types/react-test-renderer": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "babel-preset-expo": "^55.0.14",
    "eslint": "^8.57.1",
    "eslint-config-expo": "~55.0.1",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.17",
    "react-test-renderer": "^19.2.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "engines": {
    "node": ">=22 <25"
  }
}
